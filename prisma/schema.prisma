generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  latexDocs        Latex[]
  portfolio        Portfolio?
  roadmapBookmarks RoadmapBookmark[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Latex {
  id        Int            @id @default(autoincrement())
  title     String
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  LatexVersion[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model LatexVersion {
  id        Int      @id @default(autoincrement())
  content   String
  latexId   Int
  latex     Latex    @relation(fields: [latexId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Portfolio {
  id          Int      @id @default(autoincrement())
  data        Json
  isPublished Boolean  @default(false)
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Roadmap {
  id        Int      @id @default(autoincrement())
  title     String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks RoadmapBookmark[]
}

model RoadmapBookmark {
  id        Int @id @default(autoincrement())
  userId    Int
  roadmapId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
}
