generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  name      String?
  latexDocs Latex[]
  portfolio Portfolio?
  roadmaps  UserRoadmap[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Latex {
  id        Int            @id @default(autoincrement())
  title     String
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  LatexVersion[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model LatexVersion {
  id        Int      @id @default(autoincrement())
  content   String
  latexId   Int
  latex     Latex    @relation(fields: [latexId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Portfolio {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   String
  data       Json
  deployLink String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Roadmap {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  steps       RoadmapStep[]
  followers   UserRoadmap[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model RoadmapStep {
  id        Int     @id @default(autoincrement())
  title     String
  content   String
  order     Int
  roadmapId Int
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model UserRoadmap {
  id        Int     @id @default(autoincrement())
  userId    Int
  roadmapId Int
  progress  Int     @default(0)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
}
